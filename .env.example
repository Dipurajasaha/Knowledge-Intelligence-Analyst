# Knowledge Intelligence Analyst Environment Configuration
# Copy this file to scraping/settings.env and fill in your actual values

# ============================================
# 🎯 Domain & Topic Configuration
# ============================================

# Domain of interest for AI-generated topic generation
DOMAIN=Generative AI & Deep Learning

# ============================================
# 📡 Data Collection Settings
# ============================================

# Platforms to scrape (comma-separated)
PLATFORMS=Reddit,StackOverflow,DevTo

# Maximum records per topic per platform
MAX_RECORDS_PER_TOPIC=100

# Number of topics to generate
TOPIC_COUNT=5

# Output directory for raw data
RAW_DATA_DIR=./data/raw

# ============================================
# 🔧 Reddit Configuration
# ============================================

# Reddit User-Agent (required to avoid blocking)
# Format: reddit-bot-name/version (by /u/username)
REDDIT_USER_AGENT=python:projectdatacollector:v1.0

# ============================================
# 🤖 LLM Configuration (LongCat API)
# ============================================

# LongCat API Key (required for topic generation)
# Get it from: https://longcat.chat/
LONGCAT_API_KEY=your_api_key_here

# LongCat Model Name
# Example: gpt-4, gpt-3.5-turbo, or other available models
LONGCAT_MODEL=gpt-3.5-turbo

# ============================================
# 📊 Optional: Advanced Settings
# ============================================

# Add any additional configuration as needed
# Examples:
# REQUEST_TIMEOUT=30
# RETRY_ATTEMPTS=3
# PAGINATION_LIMIT=500
